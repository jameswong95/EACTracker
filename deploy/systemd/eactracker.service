[Unit]
Description=EACTracker Docker Compose application
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
WorkingDirectory=/opt/eactracker
RemainAfterExit=yes
ExecStart=/usr/bin/docker compose -f deploy/docker-compose.prod.yml up -d
ExecStop=/usr/bin/docker compose -f deploy/docker-compose.prod.yml down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target

