NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/eac_tracker

# Comma-separated allowed browser origins when frontend/backend are split.
# Leave blank in same-origin production deployments.
CORS_ORIGIN=http://localhost:5173

# Demo login is enabled by default only outside production.
# Set ALLOW_DEMO_AUTH=1 only for controlled demo/internal deployments.
ALLOW_DEMO_AUTH=1

# Production API authentication.
# Use AUTH_MODE=proxy behind an authenticated reverse proxy / SSO gateway.
# The proxy must strip any incoming client-supplied auth headers, then inject:
#   x-auth-proxy-secret: <AUTH_PROXY_SECRET>
#   x-auth-user-id: <numeric app user id>
#   x-auth-username: <username/email>
#   x-auth-role: Admin|Project Manager|Project Director|Leader|Finance
AUTH_MODE=demo
AUTH_PROXY_SECRET=
AUTH_PROXY_SECRET_HEADER=x-auth-proxy-secret
AUTH_USER_ID_HEADER=x-auth-user-id
AUTH_USERNAME_HEADER=x-auth-username
AUTH_ROLE_HEADER=x-auth-role

# Optional first UAT admin fallback while Entra app roles are being configured.
# If the authenticated proxy username/email matches this value, the backend grants
# BOOTSTRAP_ADMIN_ROLE even when no role claim is present.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_ROLE=Admin

# Managed Postgres providers often require SSL.
DATABASE_SSL=0
DATABASE_SSL_ALLOW_SELF_SIGNED=0

PG_POOL_MAX=10
PG_CONNECTION_TIMEOUT_MS=10000
PG_IDLE_TIMEOUT_MS=30000
PG_STATEMENT_TIMEOUT_MS=30000
TRUST_PROXY=0
LOG_SQL=0

# OWASP hardening knobs.
JSON_BODY_LIMIT=1mb
UPLOAD_MAX_BYTES=10485760
SAP_MAX_ROWS=25000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5000
