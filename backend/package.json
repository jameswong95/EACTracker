{
  "name": "pfms-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "migrate": "node scripts/migrate-all.mjs",
    "migrate:list": "node scripts/migrate-all.mjs --list",
    "seed": "node scripts/run-sql.mjs db/seed/demo.sql",
    "db:deploy": "npm run migrate",
    "db:setup": "npm run db:deploy",
    "db:setup:demo": "npm run migrate && npm run seed",
    "security:audit": "npm audit --omit=dev",
    "security:check": "npm run migrate:list && npm run security:audit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^2.0.0",
    "pg": "^8.12.0",
    "xlsx": "^0.18.5"
  }
}
